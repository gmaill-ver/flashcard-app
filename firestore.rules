rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 本人のデータのみアクセス可能
    match /users/{uid} {
      allow read, write: if request.auth != null &&
                            request.auth.token.email == 'u.t.o0911@gmail.com' &&
                            request.auth.uid == uid;

      match /cards/{cardId} {
        allow read, write: if request.auth != null &&
                              request.auth.token.email == 'u.t.o0911@gmail.com';
      }
    }

    // 公開デッキのメタデータ（読み取り専用）
    match /publicDecks/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // グローバル統計（読み取り専用）
    match /meta/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // その他すべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
